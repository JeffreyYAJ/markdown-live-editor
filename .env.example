# App
APP_URL=http://localhost:5173
PORT=3001

# Auth — use a long random string in production (32+ chars)
# Generate: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# Database (SQLite)
DATABASE_URL=./data/app.db

# Per-user file storage root (data/users/{userId}/)
DATA_ROOT=./data

# OAuth — optional; buttons appear when both ID + secret are set
# Redirect URIs (register in each provider console):
#   Google:  http://localhost:5173/api/auth/google/callback
#   GitHub:  http://localhost:5173/api/auth/github/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Legacy — ignored when auth is enabled
# WORKSPACE_ROOT=./workspace
